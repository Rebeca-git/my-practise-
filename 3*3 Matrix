#include <stdio.h>
int main() {
    int arr[9], i;
    printf("Enter 9 numbers:\n");
    for(i = 0; i < 9; i++) {
        scanf("%d", &arr[i]);
    }
    printf("3x3 Matrix:\n");
    for(i = 0; i < 9; i++) {
        printf("%d\t", arr[i]);
        if((i + 1) % 3 == 0) printf("\n"); // New line after every 3 numbers
    }
    return 0;
}
